# Set this only when XTTS cannot find a bundled speaker for the chosen model.
# XTTS_SPEAKER_WAV=C:\\path\\to\\licensed-reference.wav

# Optional: select a known built-in XTTS speaker name when the model exposes one.
# XTTS_SPEAKER=

# French and German audio use Coqui XTTS-v2. Only set this after reading and
# accepting the CPML terms at https://coqui.ai/cpml.
# COQUI_TOS_AGREED=1

# Hindi and Tamil audio use a gated Hugging Face model. After accepting its
# terms at https://huggingface.co/ai4bharat/indic-parler-tts, create a read
# token at https://huggingface.co/settings/tokens and paste it here.
HF_TOKEN=your_token_here
